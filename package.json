{
  "name": "gary",
  "version": "0.1.0",
  "description": "Gary - Dungeon Master Assistant Agent for D&D 5e",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "tsc -p tsconfig.preload.json --watch",
    "dev:renderer": "vite",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:preload\" \"npm run dev:renderer\"",
    "start": "npm run build && electron dist/main/index.js",
    "start:dev": "NODE_ENV=development electron dist/main/index.js",
    "lint": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:main": "vitest --config vitest.config.main.ts",
    "test:renderer": "vitest --config vitest.config.renderer.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "verify": "npm run lint && npm run test:run && npm run build",
    "ci": "npm run verify"
  },
  "keywords": [
    "electron",
    "dnd",
    "dungeon-master",
    "assistant"
  ],
  "author": "Yannis Mentekidis",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@tailwindcss/typography": "^0.5.19",
    "diff": "^8.0.3",
    "electron": "^28.0.0",
    "gray-matter": "^4.0.3",
    "js-tiktoken": "^1.0.21",
    "react": "^18.2.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^7.0.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron-builder": "^24.0.0",
    "happy-dom": "^20.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.16"
  }
}
